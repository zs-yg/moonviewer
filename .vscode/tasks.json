{
    "version": "2.0.0",
    "tasks": [
        {
            "label": "Build with Nuitka(msvc)",
            "type": "shell",
            "command": "nuitka",
            "args": [
                "--standalone",
                "--msvc=latest",
                "--windows-icon-from-ico=icon.ico",
                "--windows-company-name=\"zs-yg\"",
                "--windows-product-name=\"MoonViewer\"",
                "--windows-file-version=\"1.1.3\"",
                "--windows-product-version=\"1.1.3\"",
                "--windows-file-description=\"MoonViewer\"",
                "--remove-output",
                "--jobs=2",
                "--lto=yes",
                "--output-filename=MoonViewer.exe",
                "--windows-console-mode=disable",
                "--enable-plugin=pyside6",
                "--output-dir=dist",
                "main.py"
            ],
            "group": "build",
            "detail": "使用nuitka进行msvc编译",
        },
        {
            "label": "Install the requirements",
            "type": "shell",
            "command": "pip",
            "args": [
                "install",
                "-r",
                "requirements.txt"
            ],
            "group": "build",
            "detail": "安装依赖包",
        }
    ]
}